// Prisma Schema for Employee Expense Reimbursement System

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  MANAGER
  EMPLOYEE
}

enum ExpenseStatus {
  DRAFT
  WAITING_APPROVAL
  APPROVED
  REJECTED
  PAID
}

enum ApprovalStepStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─── Models ───────────────────────────────────────────────────────────────────

model Company {
  id              String   @id @default(uuid())
  name            String
  country         String
  defaultCurrency String   @default("INR") @map("default_currency")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  users          User[]
  approvalRules  ApprovalRule[]

  @@map("companies")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  role      Role     @default(EMPLOYEE)
  companyId String   @map("company_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company   Company  @relation(fields: [companyId], references: [id])
  expenses  Expense[]
  approvalSteps ApprovalStep[] @relation("Approver")

  @@map("users")
}

model Category {
  id        String   @id @default(uuid())
  name      String   @unique
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  expenses Expense[]

  @@map("categories")
}

model Expense {
  id               String        @id @default(uuid())
  description      String
  amount           Decimal       @db.Decimal(12, 2)
  currency         String        @default("INR")
  convertedAmount  Decimal       @db.Decimal(12, 2) @map("converted_amount")
  conversionRate   Decimal       @db.Decimal(12, 6) @map("conversion_rate")
  date             DateTime      @db.Date
  vendor           String?
  receiptUrl       String?       @map("receipt_url")
  status           ExpenseStatus @default(DRAFT)
  categoryId       String        @map("category_id")
  userId           String        @map("user_id")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  category      Category       @relation(fields: [categoryId], references: [id])
  user          User           @relation(fields: [userId], references: [id])
  approvalSteps ApprovalStep[]

  @@index([userId, status])
  @@map("expenses")
}

model ApprovalRule {
  id          String   @id @default(uuid())
  companyId   String   @map("company_id")
  stepOrder   Int      @map("step_order")
  approverRole Role    @map("approver_role")
  createdAt   DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, stepOrder])
  @@map("approval_rules")
}

model ApprovalStep {
  id          String            @id @default(uuid())
  expenseId   String            @map("expense_id")
  stepOrder   Int               @map("step_order")
  approverId  String?           @map("approver_id")
  status      ApprovalStepStatus @default(PENDING)
  comment     String?
  decidedAt   DateTime?         @map("decided_at")
  createdAt   DateTime          @default(now()) @map("created_at")

  expense  Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  approver User?   @relation("Approver", fields: [approverId], references: [id])

  @@unique([expenseId, stepOrder])
  @@map("approval_steps")
}
